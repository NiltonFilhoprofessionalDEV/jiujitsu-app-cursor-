NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Comma-separated emails that can access /admin (authorize owners, manage academies)
PLATFORM_ADMIN_EMAILS=

# Web Push (generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:seu-email@academia.com

# Cron secret (Bearer) for /api/cron/* routes
CRON_SECRET=
# Public site URL for Netlify scheduled functions (auto-sessions + class-reminders)
SITE_URL=
NEXT_PUBLIC_APP_URL=
# GitHub Actions also needs repository secrets: APP_BASE_URL + CRON_SECRET
# (Vercel Hobby native cron only runs once/day — not enough for auto-open)

# Optional: send invite emails via Resend (otherwise UI opens mailto)
RESEND_API_KEY=
RESEND_FROM_EMAIL=
