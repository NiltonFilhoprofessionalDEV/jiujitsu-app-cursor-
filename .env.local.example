NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Comma-separated emails that can generate owner-invite links
PLATFORM_ADMIN_EMAILS=

# Web Push (generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:seu-email@academia.com

# Cron (Netlify scheduled function → /api/cron/class-reminders)
CRON_SECRET=
# Optional: public site URL used by Netlify function (else uses URL/DEPLOY_PRIME_URL)
SITE_URL=
NEXT_PUBLIC_APP_URL=

# Optional: send invite emails via Resend (otherwise UI opens mailto)
RESEND_API_KEY=
RESEND_FROM_EMAIL=
